datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model tasks {
  id         String   @id
  client     String?
  title      String?
  type       String?
  assigned   String?
  due        String?
  stage      Int?
  notes      Json?
  revisions  Int?
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

